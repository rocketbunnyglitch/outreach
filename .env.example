# =========================================================================
# CRAWL OUTREACH ENGINE — Environment Configuration
# =========================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# Production: lives at /var/www/crawl-engine/.env, preserved across deploys
# by scripts/update-from-zip.sh.
#
# Local dev: copy to .env at repo root; defaults below work with the
# docker compose stack in compose.yaml.
#
# Variables are grouped by phase. Phase 0 is the minimum required for
# `pnpm dev` to start. Later-phase variables can stay blank during early
# development; the env validator (lib/env.ts) will surface what's missing
# when a feature actually needs it.

# =========================================================================
# PHASE 0 — Core runtime (required)
# =========================================================================

# Environment label. One of: development | staging | production
NODE_ENV=development

# Where the app thinks it's running. Used for OAuth callbacks, public URLs.
# Production: https://admin.barcrawlconnect.com
# Local:      http://localhost:3001
APP_URL=http://localhost:3001

# Internal port. Caddy reverse-proxies to this in production. Local dev too.
PORT=3001

# Postgres connection string for the crawl_engine database.
# Local docker compose: postgresql://crawl_engine_app:devpass@127.0.0.1:5433/crawl_engine
# Production: filled in by scripts/setup-server.sh (password printed once).
DATABASE_URL=postgresql://crawl_engine_app:devpass@127.0.0.1:5433/crawl_engine

# Redis. Logical DB 1 to avoid colliding with anything else.
# Local:      redis://127.0.0.1:6379/1
# Production: redis://127.0.0.1:6379/1 (host Redis, logical DB 1)
REDIS_URL=redis://127.0.0.1:6379/1

# Cryptographic seed for libsodium encryption of stored OAuth tokens, Postmark
# tokens, Eventbrite tokens, etc. Generate once with:
#   openssl rand -hex 32
# NEVER rotate without re-encrypting stored secrets — see DECISIONS.md (TBD).
APP_ENCRYPTION_KEY=

# =========================================================================
# PHASE 3 — Auth (required for login)
# =========================================================================

# NextAuth.js (Auth.js v5) secret. Sign session JWTs. Generate with:
#   openssl rand -hex 32
NEXTAUTH_SECRET=

# Google OAuth — the admin login provider.
# Console: https://console.cloud.google.com/apis/credentials
# Configure OAuth consent screen restricted to your Workspace domain.
# Authorized redirect URI: ${APP_URL}/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Restrict admin login to this Google Workspace domain (e.g. eventsperse.com).
# Empty = no restriction (DO NOT ship to prod with this empty).
GOOGLE_WORKSPACE_DOMAIN=

# Enables the dev impersonation Credentials provider on the login page,
# letting you sign in as any seeded staff_members row by email — no OAuth.
# Set to "1" in development and demo environments only.
#
# This intentionally does NOT key off NODE_ENV: Next.js standalone hard-codes
# NODE_ENV=production at server.js startup, so we can't gate on it reliably.
# Belt-and-suspenders: even if you set this to "1" in production, it stays
# disabled when GOOGLE_OAUTH_CLIENT_ID is set.
ENABLE_DEV_IMPERSONATION=

# =========================================================================
# PHASE 5 — Lead generation (Google Maps Platform)
# =========================================================================

# Single API key with these APIs enabled:
#   - Places API (New)
#   - Distance Matrix API
#   - Geocoding API
# Restrict by server IP in production.
GOOGLE_MAPS_API_KEY=

# ZeroBounce email validation. Pay-as-you-go.
# https://www.zerobounce.net/
ZEROBOUNCE_API_KEY=

# =========================================================================
# PHASE 6 — Outreach automation
# =========================================================================

# Postmark — ONE ACCOUNT PER OUTREACH BRAND (DECISIONS.md#015).
# Per-brand credentials are stored encrypted in the `outreach_brands` table,
# not here. These env vars are only the fallback for transactional sends
# from the engine itself (e.g. admin password-reset emails, if any).
POSTMARK_FALLBACK_SERVER_TOKEN=
POSTMARK_FALLBACK_SENDER=noreply@barcrawlconnect.com

# Quo (call API). Per-staff or per-brand credentials TBD in Phase 6.
QUO_API_KEY=
QUO_API_BASE_URL=https://api.example-quo.com

# =========================================================================
# PHASE 7 — Confirmation automations
# =========================================================================

# Puppeteer for poster generation. By default uses bundled Chromium.
# Set this to use a system Chromium (e.g. on the production server):
#   PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=

# =========================================================================
# PHASE 8 — External sync + backups
# =========================================================================

# Eventbrite — ONE ORG PER CRAWL BRAND. Per-brand credentials in DB, similar
# to Postmark. This is a fallback (e.g. for the OpenAPI generator / docs).
EVENTBRITE_FALLBACK_TOKEN=

# Backblaze B2 (DECISIONS.md#014). For the backup script to upload off-host.
# Configured via `rclone config` on the server, but documented here for
# reference. B2_BUCKET goes in /var/www/crawl-engine/.env so the cron job
# can read it.
B2_BUCKET=crawl-engine-backups

# =========================================================================
# BUILD-TIME (set by scripts/build-with-version.sh — do not set manually)
# =========================================================================
# BUILD_VERSION   # semver from VERSION file
# BUILD_COMMIT    # git rev-parse --short HEAD
# BUILD_AT        # ISO 8601 build timestamp
