#!/usr/bin/env sh

# Enforces Conventional Commits via commitlint.
# Uses npm (matches the package-lock.json in this repo).

npm exec -- commitlint --edit "$1" || {
  echo ""
  echo "X Commit message does not follow Conventional Commits."
  echo ""
  echo "Format: <type>(<scope>)?: <subject>"
  echo "Types:  feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert"
  echo ""
  echo "Examples:"
  echo "  feat(outreach): add gmail oauth callback handler"
  echo "  fix(db): correct migration ordering for venue_events"
  echo "  docs(architecture): note tz strategy for cross-city views"
  exit 1
}
