#!/usr/bin/env sh

# Pre-commit: run Biome on staged files, then typecheck the whole project.
# Fast failures are good — keep this lean.

# Biome check on the whole repo is faster than per-file in practice (it
# warm-caches everything). If this becomes too slow, switch to lint-staged.
pnpm exec biome check . || {
  echo ""
  echo "❌ Biome found issues. Fix with: pnpm lint:fix"
  exit 1
}

# Typecheck. Slow path; revisit if it becomes a friction point.
pnpm typecheck || {
  echo ""
  echo "❌ TypeScript errors. Fix before committing."
  exit 1
}
