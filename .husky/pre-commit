#!/usr/bin/env sh

# Pre-commit: run Biome on the repo, then typecheck.
# Uses npm (matches the package-lock.json in this repo). If you switch
# to pnpm later, change these to 'pnpm exec' / 'pnpm typecheck'.

npm exec biome check . || {
  echo ""
  echo "X Biome found issues. Fix with: npm run lint:fix"
  exit 1
}

npm run typecheck || {
  echo ""
  echo "X TypeScript errors. Fix before committing."
  exit 1
}
