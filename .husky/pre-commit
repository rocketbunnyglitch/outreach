#!/usr/bin/env sh

# Pre-commit: run Biome on the repo, then typecheck.
# Uses npm (matches the package-lock.json in this repo). If you switch
# to pnpm later, change these to 'pnpm exec' / 'pnpm typecheck'.

npm exec biome check . || {
  echo ""
  echo "X Biome found issues. Fix with: npm run lint:fix"
  exit 1
}

npm run typecheck || {
  echo ""
  echo "X TypeScript errors. Fix before committing."
  exit 1
}

# Hydration-safety guardrail: blocks client components that read browser state
# (localStorage/sessionStorage/cookies/navigator) during render or in a
# useState/useMemo/useRef initializer, and unpinned toLocale*() — the recurring
# "freezes on my profile but works in incognito" class. See
# scripts/check-hydration-safety.cjs (clock reads are advisory warnings only).
node scripts/check-hydration-safety.cjs || {
  echo ""
  echo "X Hydration-safety check failed. Read browser state in useEffect (not render),"
  echo "  or use suppressHydrationWarning for intentional timestamps."
  exit 1
}

# Reference-doc drift guard: block the commit if a loaded reference doc changed
# without a reload. Skips gracefully when the DB is unreachable / DATABASE_URL
# is unset (deploy re-loads as the safety net).
npm run reference-docs:check || {
  echo ""
  echo "X Reference doc changed. Run 'npm run reference-docs:load' before committing."
  exit 1
}
